# LEA Platform - Environment Variables Template
# Copy this file to .env.local and fill in your actual credentials

# ============================================================================
# SUPABASE - PostgreSQL & Real-time Backend
# ============================================================================

# Get from: https://app.supabase.com/project/[projectId]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (for server-side operations only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# M-PESA - Payment Processing Integration
# ============================================================================

# Sandbox (Testing)
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret

# Production (Real Payments)
# MPESA_ENVIRONMENT=production
# MPESA_CONSUMER_KEY=your_production_consumer_key
# MPESA_CONSUMER_SECRET=your_production_consumer_secret

# M-Pesa Configuration
MPESA_SHORT_CODE=123456              # Your M-Pesa Business Number
MPESA_PASSTHROUGH_KEY=your_key       # Unique identifier for your account
MPESA_INITIATOR_NAME=testuser        # M-Pesa API user for this account
MPESA_INITIATOR_PASSWORD=securepass  # M-Pesa API password

# M-Pesa Webhook (where M-Pesa sends payment callbacks)
NEXT_PUBLIC_MPESA_CALLBACK_URL=https://yourdomain.com/api/webhooks/payment

# ============================================================================
# AFRICA'S TALKING - SMS, USSD, Voice Integration
# ============================================================================

# Sandbox (Testing)
AFRICASTALKING_ENVIRONMENT=sandbox
AFRICASTALKING_API_KEY=your_sandbox_api_key
AFRICASTALKING_USERNAME=sandbox

# Production (Real SMS/Voice)
# AFRICASTALKING_ENVIRONMENT=production
# AFRICASTALKING_API_KEY=your_production_api_key
# AFRICASTALKING_USERNAME=your_production_username

# Sender ID (shows as SMS sender name, max 6 chars)
AFRICASTALKING_SENDER_ID=LEA

# Africa's Talking Webhook (where AT sends SMS/status callbacks)
NEXT_PUBLIC_AFRICASTALKING_CALLBACK_URL=https://yourdomain.com/api/webhooks/sms

# SMS Configuration for Contact & Viewing Forms
# Get from: https://account.africastalking.com/
AFRICAS_TALKING_USERNAME=your_africas_talking_username
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_SENDER_ID=LEAExecutive  # Max 11 characters, must be approved by AT
LANDLORD_PHONE_NUMBER=+254700123456    # Landlord's phone for notifications

# Africa's Talking Environment
# NODE_ENV=development uses sandbox: https://api.sandbox.africastalking.com/version1/messaging
# NODE_ENV=production uses live: https://api.africastalking.com/version1/messaging

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Your application's public URL (for callbacks)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Application environment
NODE_ENV=development  # development, staging, production

# Enable debugging (set to false in production)
NEXT_PUBLIC_DEBUG_MODE=true

# Support email for customer issues
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# ============================================================================
# SECURITY & SECRETS (KEEP SECURE!)
# ============================================================================

# JWT Secret for OTP token signing
JWT_SECRET=your_super_secret_key_min_32_chars_long!

# Webhook signature secret (for validating incoming webhooks)
WEBHOOK_SECRET=another_secret_key_for_webhook_validation

# HMAC signing key for OTP tokens
OTP_SIGNING_KEY=key_for_signing_otp_tokens_securely

# Rate limiting: max requests per minute
RATE_LIMIT_REQUESTS=60

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Connection pooling
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=20000  # milliseconds

# Query timeouts
DATABASE_QUERY_TIMEOUT=30000  # milliseconds

# ============================================================================
# ERROR TRACKING & MONITORING
# ============================================================================

# Sentry (Error tracking - optional but recommended for production)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# LogRocket (Session replay - optional)
NEXT_PUBLIC_LOGROCKET_ID=your_logrocket_id

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features during development
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true

# Payment methods to enable
NEXT_PUBLIC_ENABLE_MPESA=true
NEXT_PUBLIC_ENABLE_AIRTEL_MONEY=false
NEXT_PUBLIC_ENABLE_MTN_MOMO=false

# ============================================================================
# MULTI-COUNTRY SUPPORT
# ============================================================================

# Default country for the app
DEFAULT_COUNTRY=KE  # KE, NG, UG, TZ, GH

# Supported currencies (comma-separated)
SUPPORTED_CURRENCIES=KES,NGN,UGX,TZS,GHS

# SMS delivery: country-specific configuration
SMS_COUNTRY_CODES=KE,NG,UG,TZ,GH

# ============================================================================
# DEPLOYMENT SPECIFIC
# ============================================================================

# Vercel configuration
VERCEL_PROJECT_ID=your_project_id
VERCEL_TEAM_ID=your_team_id

# Analytics (optional)
NEXT_PUBLIC_GA_ID=your_google_analytics_id

# ============================================================================
# TESTING (Only for CI/CD environments)
# ============================================================================

# Test phone number to use in tests (make sure it's not real)
TEST_PHONE_NUMBER=+254712000000

# Test M-Pesa transaction ID
TEST_MPESA_TRANSACTION_ID=TEST-TXN-001

# ============================================================================
# NOTES
# ============================================================================

# 1. NEVER commit .env.local to Git
# 2. Use .env.example for documentation
# 3. Different .env files for different environments:
#    - .env.local (local development)
#    - .env.staging (Vercel staging)
#    - .env.production (Vercel production)
# 4. In Vercel dashboard:
#    - Settings → Environment Variables
#    - Add each variable for each environment
# 5. Secrets rotation recommended monthly
# 6. All API keys should be rotated if compromised

# ============================================================================
# SETUP CHECKLIST
# ============================================================================

# [ ] Create Supabase project
# [ ] Get Supabase API keys
# [ ] Create M-Pesa developer account
# [ ] Get M-Pesa API credentials
# [ ] Create Africa's Talking account
# [ ] Get Africa's Talking API key
# [ ] Generate strong JWT_SECRET
# [ ] Generate strong WEBHOOK_SECRET
# [ ] Generate strong OTP_SIGNING_KEY
# [ ] Set NEXT_PUBLIC_APP_URL to your domain
# [ ] Configure M-Pesa callback URL in M-Pesa dashboard
# [ ] Configure Africa's Talking callback URL in AT dashboard
# [ ] Test with sandbox credentials first
# [ ] Verify all integrations work
# [ ] Switch to production credentials
# [ ] Deploy to Vercel with env vars
# [ ] Run smoke tests

# ============================================================================
# TROUBLESHOOTING REFERENCE
# ============================================================================

# Payment not being initiated?
#   → Check MPESA_CONSUMER_KEY and MPESA_CONSUMER_SECRET
#   → Verify MPESA_SHORT_CODE matches your M-Pesa account
#   → Ensure NEXT_PUBLIC_MPESA_CALLBACK_URL is in M-Pesa dashboard

# SMS not sending?
#   → Check AFRICASTALKING_API_KEY is valid
#   → Verify AFRICASTALKING_SENDER_ID format (max 6 chars)
#   → Check account has SMS balance in Africa's Talking dashboard

# Webhooks not received?
#   → Verify callback URLs are public and accessible
#   → Check firewall allows incoming webhooks
#   → Verify signature validation is not rejecting valid requests
#   → Check webhook logs in respective service dashboards

# Database connection failed?
#   → Verify NEXT_PUBLIC_SUPABASE_URL format
#   → Check NEXT_PUBLIC_SUPABASE_ANON_KEY is not expired
#   → Verify Supabase project is active
#   → Check database is not in paused state

# ============================================================================
